{
          "name": "scp-os",
          "private": true,
          "version": "0.4.0",
          "type": "module",
          "description": "SCP Foundation Web OS - Monorepo",
          "scripts": {
                    "dev": "pnpm --filter @scp-os/app dev",
                    "dev:development": "pnpm --filter @scp-os/app dev:development",
                    "dev:production": "pnpm --filter @scp-os/app dev:production",
                    "build": "pnpm --filter @scp-os/app build",
                    "build:development": "pnpm --filter @scp-os/app build:development",
                    "build:production": "pnpm --filter @scp-os/app build:production",
                    "preview": "pnpm --filter @scp-os/app preview",
                    "test": "pnpm --filter @scp-os/app test && pnpm --filter scp-scraper-worker test",
                    "test:ui": "pnpm --filter @scp-os/app test:ui",
                    "test:coverage": "pnpm --filter @scp-os/app test:coverage && pnpm --filter scp-scraper-worker test:coverage",
                    "worker:dev": "pnpm --filter scp-scraper-worker dev",
                    "worker:deploy": "pnpm --filter scp-scraper-worker deploy",
                    "worker:tail": "pnpm --filter scp-scraper-worker tail",
                    "desktop:dev": "pnpm --filter @scp-os/desktop tauri:dev",
                    "desktop:build": "pnpm --filter @scp-os/desktop tauri:build",
                    "typecheck": "pnpm --filter @scp-os/app typecheck",
                    "lint:check": "pnpm --filter @scp-os/app lint:check",
                    "lint": "eslint . --ext .ts,.vue",
                    "format": "prettier --write ."
          },
          "devDependencies": {
                    "@cloudflare/workers-types": "^4.20260411.1",
                    "typescript": "~5.9.3"
          },
          "engines": {
                    "node": ">=18.0.0",
                    "pnpm": ">=8.0.0"
          },
          "packageManager": "pnpm@10.3.0"
}
